{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pings",
  "version": "0.1.0",
  "identifier": "com.pings",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Pings",
        "width": 400,
        "height": 640,
        "minWidth": 360,
        "minHeight": 520
      },
      {
        "label": "ping-overlay",
        "title": "Ping Overlay",
        "url": "overlay.html",
        "width": 560,
        "height": 560,
        "visible": false,
        "transparent": true,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "dangerousInsecureTransportProtocol": true,
      "endpoints": [
        "http://ZachBook-Pro.local:8123/latest.json",
        "http://localhost:8123/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERGQzc5MzA0Q0FDNjU4NEQKUldSTldNYktCSlBIMzk3cytzYUx0a1VvbTUzenA5R21VTlJGaktTTGIxT2lPQ2pGUUxmQlRoVXUK"
    }
  }
}
