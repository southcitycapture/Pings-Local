# APNs push for Pings Dispatch — copy to apns.env, fill in, then:
#   set -a; source secrets/apns.env; set +a; cargo run
#
# The three real values come from the Apple Developer portal once
# enrollment clears (see go-native/README.md "Ship checklist"):
#   Certificates, Identifiers & Profiles → Keys → "+" → Apple Push
#   Notifications service (APNs) → download the .p8 (ONE download only —
#   store it somewhere safe), note its Key ID; Team ID is in Membership.

# Path to the downloaded .p8 auth key
DISPATCH_APNS_KEY=secrets/AuthKey_XXXXXXXXXX.p8
# The 10-character key id shown next to the key in the portal
DISPATCH_APNS_KEY_ID=XXXXXXXXXX
# Your 10-character Apple Team ID (Membership page)
DISPATCH_APNS_TEAM_ID=XXXXXXXXXX
# The iOS app's bundle identifier
DISPATCH_APNS_TOPIC=com.pings.go
# "sandbox" for dev-signed builds (tauri ios dev on a device),
# "production" for TestFlight / App Store builds
DISPATCH_APNS_ENDPOINT=sandbox

# The server itself
DISPATCH_TEAM_KEY=change-me
DISPATCH_STATE_FILE=secrets/dispatch-state.json
